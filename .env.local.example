# Shopify Storefront API
# These are intentionally NEXT_PUBLIC — the Storefront API token is designed for
# public client-side access. Do NOT use your Admin API token here.

# Your store's myshopify.com subdomain (e.g. "turbogixxer.myshopify.com")
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API access token — create one in Shopify Admin under
# Apps → Develop apps → your app → API credentials → Storefront API access token
# Scopes needed: unauthenticated_read_product_listings, unauthenticated_write_checkouts,
# unauthenticated_read_checkouts, unauthenticated_write_customers
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token_here

# Merch collection handle — the Shopify collection containing merch products.
# Defaults to "merch" if not set. Change to match your collection's URL handle.
NEXT_PUBLIC_SHOPIFY_MERCH_COLLECTION=merch
